    if parts[1] == "!kick" and parts[2] then
        local target = findPlayer(parts[2])

        if target then
            SelectedTarget = target.Name
            selectedKickPlayer = target
            targetDropdown:SetValue(target.Name)

            if kickLoopEnabled then
                kickLoopEnabled = false
                task.wait(0.1)
            end

            notify("Kick", "Started kicking " .. target.Name)
        end
    elseif parts[1] == "!unkick" and parts[2] then
        local target = findPlayer(parts[2])

        if target and SelectedTarget == target.Name then
            kickLoopEnabled = false
            SelectedTarget = nil
            selectedKickPlayer = nil
            notify("Kick", "Stopped kicking " .. target.Name)
        end
    elseif parts[1] == "!kill" and parts[2] then
        local target = findPlayer(parts[2])

        if target then
            SelectedTarget = target.Name
            selectedKickPlayer = target
            targetDropdown:SetValue(target.Name)

            if loopKillEnabled then
                loopKillEnabled = false
                task.wait(0.1)
            end

            if loopKillToggle then
                loopKillToggle:SetValue(true)
            end

            notify("Kill", "Started killing " .. target.Name)
        end
    end
end)

