TargetGroup:AddToggle("Kick", {
    Text = "Kick",
    Default = false,
    Callback = function(on)
        kickLoopEnabled = on

        if not on then
            normalKickTimer = nil
            slowKickTimer = nil
            normalGrabCounter = 0
            slowGrabCounter = 0
            normalOwnerCounter = 0
            slowOwnerCounter = 0
            
            if barrierConnection then
                barrierConnection:Disconnect()
                barrierConnection = nil
            end
            
            task.spawn(function()
                if selectedKickPlayer and selectedKickPlayer.Character then
                    local targetRoot = selectedKickPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if targetRoot then
                        pcall(function()
                            local GrabEvents = ReplicatedStorage:WaitForChild("GrabEvents")
                            GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                        end)
                    end
                end
            end)
            return
        end

        task.spawn(function()
            local GrabEvents = ReplicatedStorage:WaitForChild("GrabEvents")
            local SetNetworkOwner = GrabEvents:WaitForChild("SetNetworkOwner")
            
            -- УНИЧТОЖАЕМ БАРЬЕРЫ
            local function destroyBarriers()
                for _, child in pairs(Workspace:GetChildren()) do
                    if child.Name and string.find(child.Name, "Plot") then
                        local barrier = child:FindFirstChild("Barrier")
                        if barrier then
                            pcall(function()
                                barrier:Destroy()
                            end)
                        end
                        for _, part in pairs(child:GetDescendants()) do
                            if part:IsA("BasePart") and part.Name == "PlotBarrier" then
                                pcall(function()
                                    part:Destroy()
                                end)
                            end
                        end
                    end
                    if child.Name == "PlotBarrier" and child:IsA("BasePart") then
                        pcall(function()
                            child:Destroy()
                        end)
                    end
                    if child.Name == "Barrier" then
                        pcall(function()
                            child:Destroy()
                        end)
                    end
                end
            end
            
            destroyBarriers()
            
            -- Следим за новыми барьерами
            barrierConnection = Workspace.DescendantAdded:Connect(function(obj)
                if obj.Name == "PlotBarrier" or obj.Name == "Barrier" then
                    pcall(function()
                        obj:Destroy()
                    end)
                end
                if obj.Name and string.find(obj.Name, "Plot") then
                    task.wait(0.1)
                    local barrier = obj:FindFirstChild("Barrier")
                    if barrier then
                        pcall(function()
                            barrier:Destroy()
                        end)
                    end
                    for _, part in pairs(obj:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name == "PlotBarrier" then
                            pcall(function()
                                part:Destroy()
                            end)
                        end
                    end
                end
            end)

            local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then
                kickLoopEnabled = false
                return
            end

            local anchors = {}
            local orients = {}
            local dragging = false
            local grabStartTime = 0
            local grabLineCreated = false

            while kickLoopEnabled do
                local target = selectedKickPlayer
                if not target or not target.Parent then
                    break
                end

                local myCharacter = Player.Character
                myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")
                if not myRoot then
                    break
                end

                local targetCharacter = target.Character
                local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetCharacter and targetCharacter:FindFirstChild("Humanoid")

                if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                    local distance = (myRoot.Position - targetRoot.Position).Magnitude

                    if distance > 25 then
                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 2)
                        myRoot.Velocity = Vector3.zero
                    end

                    local targetY = math.min(kickOffsetY, 20)
                    local targetPos = myRoot.Position + Vector3.new(kickOffsetX, targetY, kickOffsetZ)

                    if SelectedKickMode == "Normal" then
                        if not normalKickTimer then
                            normalKickTimer = tick()
                            normalGrabCounter = 0
                            normalOwnerCounter = 0
                        end
                        if tick() - normalKickTimer >= 0.05 then
                            normalKickTimer = tick()
                            normalGrabCounter = normalGrabCounter + 1
                            normalOwnerCounter = normalOwnerCounter + 1
                            
                            if normalOwnerCounter <= 1 then
                                for _, part in pairs(targetCharacter:GetChildren()) do
                                    if part:IsA("BasePart") then
                                        pcall(function()
                                            SetNetworkOwner:FireServer(part, part.CFrame)
                                        end)
                                    end
                                end
                            end
                            if normalOwnerCounter >= 1 then
                                normalOwnerCounter = 0
                            end
                            
                            if normalGrabCounter <= 21 then
                                if not grabLineCreated then
                                    targetHumanoid.PlatformStand = true
                                    GrabEvents.SetNetworkOwner:FireServer(targetRoot, myRoot.CFrame)
                                    task.wait()
                                    GrabEvents.CreateGrabLine:FireServer(targetRoot, Vector3.zero, targetPos, false)
                                    grabLineCreated = true
                                    grabStartTime = tick()
                                end
                            end
                            
                            if grabLineCreated and normalGrabCounter <= 21 then
                                pcall(function()
                                    GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                                end)
                                grabLineCreated = false
                            end
                            
                            if normalGrabCounter >= 20 then
                                normalGrabCounter = 0
                            end
                        end
                        
                        local anchorCount = 15
                        
                        while #anchors > anchorCount do
                            local a = table.remove(anchors)
                            if a and a.Parent then a:Destroy() end
                        end
                        while #orients > anchorCount do
                            local o = table.remove(orients)
                            if o and o.Parent then o:Destroy() end
                        end

                        for i = 1, anchorCount do
                            if not anchors[i] or not anchors[i].Parent then
                                if anchors[i] then anchors[i]:Destroy() end
                                
                                local anchor = Instance.new("AlignPosition")
                                anchor.Name = "KickAnchor_" .. i
                                anchor.Mode = Enum.PositionAlignmentMode.OneAttachment
                                anchor.MaxForce = 1e12
                                anchor.MaxVelocity = 100000
                                anchor.Responsiveness = 5000
                                
                                local att = Instance.new("Attachment", targetRoot)
                                anchor.Attachment0 = att
                                anchor.Parent = targetRoot
                                anchors[i] = anchor
                                
                                local orient = Instance.new("AlignOrientation")
                                orient.Name = "KickOrient_" .. i
                                orient.Mode = Enum.OrientationAlignmentMode.OneAttachment
                                orient.MaxTorque = 1e12
                                orient.MaxAngularVelocity = 100000
                                orient.Responsiveness = 5000
                                
                                local att2 = Instance.new("Attachment", targetRoot)
                                orient.Attachment0 = att2
                                orient.Parent = targetRoot
                                orients[i] = orient
                            end
                            
                            anchors[i].Position = targetPos
                            orients[i].CFrame = targetRoot.CFrame
                        end

                    elseif SelectedKickMode == "Slow" then
                        if not slowKickTimer then
                            slowKickTimer = tick()
                            slowGrabCounter = 0
                            slowOwnerCounter = 0
                        end
                        if tick() - slowKickTimer >= 0.05 then
                            slowKickTimer = tick()
                            slowGrabCounter = slowGrabCounter + 1
                            slowOwnerCounter = slowOwnerCounter + 1
                            
                            if slowOwnerCounter <= 1 then
                                for _ = 1, 2 do
                                    for _, part in pairs(targetCharacter:GetChildren()) do
                                        if part:IsA("BasePart") then
                                            pcall(function()
                                                SetNetworkOwner:FireServer(part, part.CFrame)
                                            end)
                                        end
                                    end
                                end
                            end
                            if slowOwnerCounter >= 2 then
                                slowOwnerCounter = 0
                            end
                            
                            if slowGrabCounter <= 11 then
                                if not grabLineCreated then
                                    targetHumanoid.PlatformStand = true
                                    GrabEvents.SetNetworkOwner:FireServer(targetRoot, myRoot.CFrame)
                                    task.wait()
                                    GrabEvents.CreateGrabLine:FireServer(targetRoot, Vector3.zero, targetPos, false)
                                    grabLineCreated = true
                                    grabStartTime = tick()
                                end
                            end
                            
                            if grabLineCreated and slowGrabCounter <= 21 then
                                pcall(function()
                                    GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                                end)
                                grabLineCreated = false
                            end
                            
                            if slowGrabCounter >= 20 then
                                slowGrabCounter = 0
                            end
                        end
                        
                        local anchorCount = 25
                        
                        while #anchors > anchorCount do
                            local a = table.remove(anchors)
                            if a and a.Parent then a:Destroy() end
                        end
                        while #orients > anchorCount do
                            local o = table.remove(orients)
                            if o and o.Parent then o:Destroy() end
                        end

                        for i = 1, anchorCount do
                            if not anchors[i] or not anchors[i].Parent then
                                if anchors[i] then anchors[i]:Destroy() end
                                
                                local anchor = Instance.new("AlignPosition")
                                anchor.Name = "KickAnchor_" .. i
                                anchor.Mode = Enum.PositionAlignmentMode.OneAttachment
                                anchor.MaxForce = 1e12
                                anchor.MaxVelocity = 100000
                                anchor.Responsiveness = 5000
                                
                                local att = Instance.new("Attachment", targetRoot)
                                anchor.Attachment0 = att
                                anchor.Parent = targetRoot
                                anchors[i] = anchor
                                
                                local orient = Instance.new("AlignOrientation")
                                orient.Name = "KickOrient_" .. i
                                orient.Mode = Enum.OrientationAlignmentMode.OneAttachment
                                orient.MaxTorque = 1e12
                                orient.MaxAngularVelocity = 100000
                                orient.Responsiveness = 5000
                                
                                local att2 = Instance.new("Attachment", targetRoot)
                                orient.Attachment0 = att2
                                orient.Parent = targetRoot
                                orients[i] = orient
                            end
                            
                            anchors[i].Position = targetPos
                            orients[i].CFrame = targetRoot.CFrame
                        end
                    end

                    if tick() - grabStartTime > 0.2 then
                        dragging = true
                    end

                else
                    dragging = false
                    grabLineCreated = false
                    grabStartTime = 0

                    for _, a in pairs(anchors) do
                        if a and a.Parent then a:Destroy() end
                    end
                    anchors = {}
                    
                    for _, o in pairs(orients) do
                        if o and o.Parent then o:Destroy() end
                    end
                    orients = {}

                    if targetRoot then
                        pcall(function()
                            GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                        end)
                    end
                end

                task.wait(0.01)
            end

            for _, a in pairs(anchors) do
                if a and a.Parent then a:Destroy() end
            end
            anchors = {}
            
            for _, o in pairs(orients) do
                if o and o.Parent then o:Destroy() end
            end
            orients = {}

            if selectedKickPlayer and selectedKickPlayer.Character then
                local targetRoot = selectedKickPlayer.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    pcall(function()
                        GrabEvents.DestroyGrabLine:FireServer(targetRoot)
                    end)
                end
            end
            
            if barrierConnection then
                barrierConnection:Disconnect()
                barrierConnection = nil
            end

            kickLoopEnabled = false
        end)
    end
})

