local function clearPCLD_Human()
    for _, connection in pairs(PCLD_Human.connections) do
        if connection then
            connection:Disconnect()
        end
    end
    PCLD_Human.connections = {}

    for _, model in pairs(PCLD_Human.models) do
        if model and model.Parent then
            model:Destroy()
        end
    end
    PCLD_Human.models = {}

    for _, billboard in pairs(PCLD_Human.billboards) do
        if billboard and billboard.Parent then
            billboard:Destroy()
        end
    end
    PCLD_Human.billboards = {}

    for _, child in pairs(Workspace:GetChildren()) do
        if child.Name:find("PCLD_Human") and child:IsA("Model") then
            child:Destroy()
        end
    end
end

Players.PlayerRemoving:Connect(function(player)
    for obj, model in pairs(PCLD_Human.models) do
        local owner = nil
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (obj.Position - pl.Character.HumanoidRootPart.Position).Magnitude
                if dist < 10 then
                    owner = pl
                    break
                end
            end
        end
        if owner == player then
            if model and model.Parent then
                model:Destroy()
            end
            if PCLD_Human.billboards[obj] then
                PCLD_Human.billboards[obj]:Destroy()
            end
            PCLD_Human.models[obj] = nil
            PCLD_Human.billboards[obj] = nil
        end
    end
end)

local function createPCLD_Human(color)
    clearPCLD_Human()

    local targetNames = {"partesp", "playercharacterlocationdetector"}

    local function IsTarget(obj)
        if not obj:IsA("BasePart") then
            return false
        end
        for _, name in ipairs(targetNames) do
            if string.lower(obj.Name) == string.lower(name) then
                return true
            end
        end
        return false
    end

    local function getOwner(part)
        local closestPlayer = nil
        local closestDistance = math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            local character = p.Character
            if character then
                local root = character:FindFirstChild("HumanoidRootPart")
                if root then
                    local distance = (part.Position - root.Position).Magnitude
                    if distance < closestDistance then
                        closestDistance = distance
                        closestPlayer = p
                    end
                end
            end
        end
        return closestPlayer or Player
    end

    local function createModel(part, ownerPlayer, ownerName, ownerChar)
        local model = Instance.new("Model")
        model.Name = "PCLD_Human"
        model.Parent = Workspace

        local torso = Instance.new("Part")
        torso.Size = Vector3.new(2, 2.7, 0.9)
        torso.Color = color or PCLDColor
        torso.Material = Enum.Material.Neon
        torso.Transparency = 0.25
        torso.Anchored = true
        torso.CanCollide = false
        torso.Massless = true
        torso.Parent = model

        local head = Instance.new("Part")
        head.Size = Vector3.new(1.3, 1.3, 1.3)
        head.Shape = Enum.PartType.Block
        head.Color = color or PCLDColor
        head.Material = Enum.Material.Neon
        head.Transparency = 0.25
        head.Anchored = true
        head.CanCollide = false
        head.Massless = true
        head.Parent = model

        local leftArm = Instance.new("Part")
        leftArm.Size = Vector3.new(0.9, 2.4, 0.9)
        leftArm.Color = color or PCLDColor
        leftArm.Material = Enum.Material.Neon
        leftArm.Transparency = 0.25
        leftArm.Anchored = true
        leftArm.CanCollide = false
        leftArm.Massless = true
        leftArm.Parent = model

        local rightArm = Instance.new("Part")
        rightArm.Size = Vector3.new(0.9, 2.4, 0.9)
        rightArm.Color = color or PCLDColor
        rightArm.Material = Enum.Material.Neon
        rightArm.Transparency = 0.25
        rightArm.Anchored = true
        rightArm.CanCollide = false
        rightArm.Massless = true
        rightArm.Parent = model

        local leftLeg = Instance.new("Part")
        leftLeg.Size = Vector3.new(0.9, 2.4, 0.9)
        leftLeg.Color = color or PCLDColor
        leftLeg.Material = Enum.Material.Neon
        leftLeg.Transparency = 0.25
        leftLeg.Anchored = true
        leftLeg.CanCollide = false
        leftLeg.Massless = true
        leftLeg.Parent = model

        local rightLeg = Instance.new("Part")
        rightLeg.Size = Vector3.new(0.9, 2.4, 0.9)
        rightLeg.Color = color or PCLDColor
        rightLeg.Material = Enum.Material.Neon
        rightLeg.Transparency = 0.25
        rightLeg.Anchored = true
        rightLeg.CanCollide = false
        rightLeg.Massless = true
        rightLeg.Parent = model

        for _, child in pairs(model:GetDescendants()) do
            if child:IsA("BasePart") then
                child.CanQuery = false
                child.CanTouch = false
            end
        end

        local billboard = Instance.new("BillboardGui")
        billboard.Size = UDim2.new(0, 200, 0, 45)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = head

        local label = Instance.new("TextLabel")
        label.Text = "PCLD | " .. ownerName
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color or PCLDColor
        label.TextStrokeTransparency = 0.5
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 12
        label.TextWrapped = true
        label.Parent = billboard

        PCLD_Human.billboards[part] = billboard
        PCLD_Human.models[part] = model

        local realHumanoid = ownerChar and ownerChar:FindFirstChild("Humanoid")

        local connection = RunService.RenderStepped:Connect(function()
            if not part or not part.Parent or not torso or not torso.Parent then
                return
            end

            torso.CFrame = part.CFrame
            head.CFrame = torso.CFrame * CFrame.new(0, 2, 0)

            if ownerPlayer and PCLD_Human.billboards[part] then
                local billboardGui = PCLD_Human.billboards[part]
                local textLabel = billboardGui:FindFirstChild("TextLabel")
                if textLabel then
                    local text = "PCLD | " .. ownerName
                    if ownerPlayer == Player then
                        text = text .. "\nPing: " .. myPing .. "ms | FPS: " .. CurrentFPS
                    end
                    textLabel.Text = text
                end
            end

            local state = realHumanoid and realHumanoid:GetState() or Enum.HumanoidStateType.Running
            local moveDirection = realHumanoid and realHumanoid.MoveDirection or Vector3.zero
            local isMoving = moveDirection.Magnitude > 0.1

            if state == Enum.HumanoidStateType.Freefall then
                leftArm.CFrame = torso.CFrame * CFrame.new(-1.5, 1.2, 0) * CFrame.Angles(math.rad(-60), 0, 0)
                rightArm.CFrame = torso.CFrame * CFrame.new(1.5, 1.2, 0) * CFrame.Angles(math.rad(-60), 0, 0)
                leftLeg.CFrame = torso.CFrame * CFrame.new(-0.5, -2, 0) * CFrame.Angles(math.rad(20), 0, 0)
                rightLeg.CFrame = torso.CFrame * CFrame.new(0.5, -2, 0) * CFrame.Angles(math.rad(-20), 0, 0)
            elseif state == Enum.HumanoidStateType.Jumping then
                leftArm.CFrame = torso.CFrame * CFrame.new(-1.5, 0.8, 0) * CFrame.Angles(math.rad(-30), 0, 0)
                rightArm.CFrame = torso.CFrame * CFrame.new(1.5, 0.8, 0) * CFrame.Angles(math.rad(-30), 0, 0)
                leftLeg.CFrame = torso.CFrame * CFrame.new(-0.5, -2.2, 0) * CFrame.Angles(0, 0, math.rad(15))
                rightLeg.CFrame = torso.CFrame * CFrame.new(0.5, -2.2, 0) * CFrame.Angles(0, 0, math.rad(-15))
            elseif isMoving then
                local time = tick() * 10
                leftArm.CFrame = torso.CFrame * CFrame.new(-1.5, 0.3, 0) * CFrame.Angles(math.sin(time) * 0.4, 0, 0)
                rightArm.CFrame = torso.CFrame * CFrame.new(1.5, 0.3, 0) * CFrame.Angles(math.cos(time) * 0.4, 0, 0)
                leftLeg.CFrame = torso.CFrame * CFrame.new(-0.5, -2.4, 0) * CFrame.Angles(math.cos(time) * 0.4, 0, 0)
                rightLeg.CFrame = torso.CFrame * CFrame.new(0.5, -2.4, 0) * CFrame.Angles(math.sin(time) * 0.4, 0, 0)
            else
                leftArm.CFrame = torso.CFrame * CFrame.new(-1.5, 0.3, 0)
                rightArm.CFrame = torso.CFrame * CFrame.new(1.5, 0.3, 0)
                leftLeg.CFrame = torso.CFrame * CFrame.new(-0.5, -2.4, 0)
                rightLeg.CFrame = torso.CFrame * CFrame.new(0.5, -2.4, 0)
            end

            for _, obj in ipairs(model:GetDescendants()) do
                if obj:IsA("ObjectValue") and string.find(obj.Name, "GrabLine") then
                    obj:Destroy()
                end
                if obj:IsA("RopeConstraint") or obj:IsA("SpringConstraint") then
                    if (obj.Attachment0 and obj.Attachment0.Parent and obj.Attachment0.Parent.Parent == Workspace) or
                       (obj.Attachment1 and obj.Attachment1.Parent and obj.Attachment1.Parent.Parent == Workspace) then
                        obj:Destroy()
                    end
                end
            end
        end)

        table.insert(PCLD_Human.connections, connection)

        part.AncestryChanged:Connect(function(_, parent)
            if not parent and PCLD_Human.models[part] then
                PCLD_Human.models[part]:Destroy()
                PCLD_Human.models[part] = nil
            end
        end)
    end

    local function scan()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if IsTarget(obj) and not PCLD_Human.models[obj] then
                local ownerPlayer = getOwner(obj)
                local ownerName = ownerPlayer.Name
                local ownerChar = ownerPlayer.Character
                createModel(obj, ownerPlayer, ownerName, ownerChar)
            end
        end
    end

    scan()

    local descendantConnection = Workspace.DescendantAdded:Connect(function(obj)
        if IsTarget(obj) and not PCLD_Human.models[obj] then
            local ownerPlayer = getOwner(obj)
            local ownerName = ownerPlayer.Name
            local ownerChar = ownerPlayer.Character
            createModel(obj, ownerPlayer, ownerName, ownerChar)
        end
    end)
    table.insert(PCLD_Human.connections, descendantConnection)

    local function onPlayerAdded(player)
        player.CharacterAdded:Connect(function()
            if PCLD_Human.enabled then
                task.wait(1)
                scan()
            end
        end)
    end

    for _, p in ipairs(Players:GetPlayers()) do
        onPlayerAdded(p)
    end

    table.insert(PCLD_Human.connections, Players.PlayerAdded:Connect(onPlayerAdded))

    PCLD_Human.enabled = true
end

